---
/**
 * SameGarden.astro — the shared "From the same garden" cross-promo grid.
 * Plain CSS on the family tokens, so it works on every site (Tailwind or not).
 *
 * Prop:
 *   current — this site's package name (e.g. "wicked-estate"); that card is
 *             excluded so a site never cross-promotes itself. No hardcoding
 *             per site — just pass the package name.
 */
const { current = '' } = Astro.props;

const SITES = [
  {
    name: 'wicked-interactive',
    href: 'https://wi.wickedagile.com',
    tagline: 'If you can say it, you can make it.',
    blurb: "Describe a page, deck, or demo out loud and watch it build live in your browser. Point at what's wrong and say what to fix.",
    tags: ['MIT', 'Claude plugin', 'live builder'],
  },
  {
    name: 'wicked-garden',
    href: 'https://wg.wickedagile.com',
    tagline: 'The local-first toolkit for AI-native development.',
    blurb: 'One gate that reads the shape of your work and applies exactly the right rigor — evidence-gated phases, 40+ specialist agents, no black box.',
    tags: ['MIT', 'Claude plugin', '9 archetypes'],
  },
  {
    name: 'wicked-estate',
    href: 'https://we.wickedagile.com',
    tagline: 'The code graph agents actually trust.',
    blurb: 'Turn any repo into a queryable graph — symbols, calls, types, refs across any language. Built for LLM agents.',
    tags: ['MIT', 'Rust', 'MCP'],
  },
];

const sites = SITES.filter((s) => s.name !== current);
---

<section class="same-garden" aria-labelledby="sg-h">
  <div class="sg-inner">
    <div class="sg-head">
      <span class="kicker">From the same garden</span>
      <h2 class="sg-h2" id="sg-h">More tools. Same ethos.</h2>
      <p class="sg-sub">Local-first, no cloud dependency, no checkmark you can't re-run.</p>
    </div>
    <div class="sg-grid">
      {sites.map((s) => (
        <a class="sg-card" href={s.href}>
          <span class="sg-pkg">wicked-</span>
          <h3 class="sg-name">{s.name.replace('wicked-', '')}</h3>
          <p class="sg-tagline">{s.tagline}</p>
          <p class="sg-blurb">{s.blurb}</p>
          <div class="sg-foot">
            <div class="sg-tags">{s.tags.map((t) => <span class="sg-tag">{t}</span>)}</div>
            <span class="sg-visit">visit ↗</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style is:global>
.same-garden{ border-top:1px solid var(--hairline); padding:clamp(48px,8vh,96px) 0; background:color-mix(in oklab, var(--canvas-2) 60%, transparent); scroll-snap-align:start; min-height:100svh; display:flex; flex-direction:column; justify-content:center; }
.same-garden .sg-inner{ max-width:1240px; margin:0 auto; padding:0 28px; }
.same-garden .sg-head{ text-align:center; margin-bottom:clamp(28px,4vh,44px); }
.same-garden .sg-h2{ font-family:var(--font-display); font-weight:900; font-stretch:125%; font-size:clamp(2rem,4vw,3rem); color:var(--ink); margin:10px 0 0; letter-spacing:-.02em; }
.same-garden .sg-sub{ font-family:var(--font-mono); font-size:.74rem; color:var(--muted); margin:14px auto 0; max-width:52ch; line-height:1.6; }
.same-garden .sg-grid{ display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:18px; }
.same-garden .sg-card{ display:flex; flex-direction:column; padding:22px; border:1px solid var(--hairline); border-radius:16px; background:color-mix(in oklab, var(--surface) 80%, transparent); text-decoration:none; transition:border-color .22s var(--ease), transform .22s var(--ease); }
.same-garden .sg-card:hover{ border-color:var(--accent); transform:translateY(-2px); }
.same-garden .sg-pkg{ font-family:var(--font-mono); font-size:.6rem; letter-spacing:.18em; text-transform:uppercase; color:var(--faint); }
.same-garden .sg-name{ font-family:var(--font-display); font-weight:900; font-stretch:125%; font-size:1.5rem; color:var(--ink); line-height:1; margin:2px 0 0; }
.same-garden .sg-tagline{ font-family:var(--font-mono); font-size:.72rem; color:var(--ink); margin:10px 0 0; }
.same-garden .sg-blurb{ font-size:.9rem; color:var(--muted); line-height:1.6; margin:10px 0 0; flex:1; }
.same-garden .sg-foot{ display:flex; align-items:center; justify-content:space-between; gap:10px; margin-top:18px; padding-top:14px; border-top:1px solid var(--hairline); }
.same-garden .sg-tags{ display:flex; flex-wrap:wrap; gap:6px; }
.same-garden .sg-tag{ font-family:var(--font-mono); font-size:.56rem; letter-spacing:.06em; text-transform:uppercase; color:var(--muted); border:1px solid var(--hairline-strong); border-radius:999px; padding:3px 8px; }
.same-garden .sg-visit{ font-family:var(--font-mono); font-size:.68rem; color:var(--faint); white-space:nowrap; }
.same-garden .sg-card:hover .sg-visit{ color:var(--accent); }
</style>
