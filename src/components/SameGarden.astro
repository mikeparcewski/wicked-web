---
/**
 * SameGarden.astro — the shared "From the toolbox" cross-promo grid.
 * Each card is a MINI BROWSER previewing the tool's site: a browser bar (dots +
 * URL), a light hero viewport (the tool's motif as imagery + headline), and a
 * bottom status bar with the --flag tags.
 *
 * Prop:
 *   current — this site's package name; that card is excluded. Dynamic 2-4 cards.
 */
const { current = '' } = Astro.props;

// Only the tools are promoted — wickedagile is the umbrella/landing, never a card.
const SITES = [
  {
    name: 'wicked-interactive', motif: 'storyboard',
    href: 'https://wi.wickedagile.com',
    tagline: 'If you can say it, you can make it.',
    blurb: 'Describe a page, deck, or demo out loud and watch it build live in your browser.',
    tags: ['MIT', 'Claude plugin', 'live builder'],
  },
  {
    name: 'wicked-garden', motif: 'trellis',
    href: 'https://wg.wickedagile.com',
    tagline: 'The local-first kit for AI-native dev.',
    blurb: 'One gate that reads the shape of your work and applies exactly the right rigor — no black box.',
    tags: ['MIT', 'Claude plugin', '9 archetypes'],
  },
  {
    name: 'wicked-estate', motif: 'graph',
    href: 'https://we.wickedagile.com',
    tagline: 'The code graph agents actually trust.',
    blurb: 'Turn any repo into a queryable graph — symbols, calls, types, refs across any language.',
    tags: ['MIT', 'Rust', 'MCP'],
  },
  {
    name: 'wicked-signals', motif: 'wave',
    href: 'https://github.com/mikeparcewski/wicked-signals',
    tagline: 'Text in. Intent out.',
    blurb: 'Classifies any signal and routes it to the right crew with confidence-tiered precision.',
    tags: ['MIT', 'TypeScript', 'npm'],
  },
  {
    name: 'wicked-crew', motif: 'bridge',
    href: 'https://github.com/mikeparcewski/wicked-crew',
    tagline: 'The session layer your agent teams need.',
    blurb: 'Phase-gated crew sessions with HITL, council voting, and a local SQLite audit trail.',
    tags: ['MIT', 'npm', 'HITL'],
  },
  {
    name: 'wicked-studio', motif: 'studio',
    href: 'https://github.com/mikeparcewski/wicked-studio',
    tagline: 'The UI your agent should have.',
    blurb: 'Desktop HITL shell — Tauri-powered, stateful, offline. Human-in-the-loop done properly.',
    tags: ['MIT', 'Rust', 'Tauri'],
  },
];

// Faint per-tool motif fragments (recolour via currentColor).
const MOTIFS = {
  graph: `<svg viewBox="0 0 300 170" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <line x1="150" y1="86" x2="70" y2="36"/><line x1="150" y1="86" x2="44" y2="120"/><line x1="150" y1="86" x2="220" y2="40"/><line x1="150" y1="86" x2="258" y2="120"/><line x1="150" y1="86" x2="110" y2="150"/><line x1="220" y1="40" x2="284" y2="20"/><line x1="44" y1="120" x2="20" y2="150"/><line x1="70" y1="36" x2="86" y2="8"/>
    <g fill="currentColor" stroke="none"><circle cx="150" cy="86" r="7"/><circle cx="70" cy="36" r="3.5"/><circle cx="44" cy="120" r="3.5"/><circle cx="220" cy="40" r="4.5"/><circle cx="258" cy="120" r="3.5"/><circle cx="110" cy="150" r="3"/><circle cx="284" cy="20" r="2.5"/><circle cx="20" cy="150" r="2.5"/><circle cx="86" cy="8" r="2.5"/></g>
  </svg>`,
  trellis: `<svg viewBox="0 0 300 170" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <g opacity="0.5"><path d="M50 0v170M120 0v170M190 0v170M260 0v170"/><path d="M0 55h300M0 115h300"/></g>
    <path d="M62 170C40 130 82 108 60 70C46 42 70 30 58 0"/><path d="M232 170C254 130 212 108 234 70C248 42 224 30 236 0"/>
    <path d="M58 56c-18-13-30-10-38-2c8 13 22 17 38 2z" fill="currentColor" stroke="none"/><path d="M236 98c18-13 30-10 38-2c-8 13-22 17-38 2z" fill="currentColor" stroke="none"/><path d="M60 112c-16-12-27-9-34-2c7 12 20 16 34 2z" fill="currentColor" stroke="none"/>
  </svg>`,
  storyboard: `<svg viewBox="0 0 300 170" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <rect x="20" y="46" width="64" height="78" rx="6"/><path d="M32 70h40M32 86h28M32 102h44"/>
    <rect x="118" y="46" width="64" height="78" rx="6"/><path d="M130 66l22-12v56M130 108h40"/>
    <rect x="216" y="46" width="64" height="78" rx="6"/><circle cx="242" cy="74" r="11"/><path d="M228 110c12-26 24 8 32-6"/>
    <path d="M88 85h18M92 78l9 7l-9 7"/><path d="M186 85h18M190 78l9 7l-9 7"/>
  </svg>`,
  wave: `<svg viewBox="0 0 300 170" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
  <path d="M10 85 C30 40 50 40 70 85 C90 130 110 130 130 85 C150 40 170 40 190 85 C210 130 230 130 250 85 C268 42 282 42 295 85"/>
  <line x1="70" y1="65" x2="70" y2="105" stroke-width="1"/>
  <line x1="190" y1="65" x2="190" y2="105" stroke-width="1"/>
  <path d="M262 52l22 12-22 12M262 94l22 12-22 12" stroke-width="1.2"/>
  <g fill="currentColor" stroke="none"><circle cx="10" cy="85" r="3"/><circle cx="130" cy="85" r="5"/><circle cx="250" cy="85" r="3"/></g>
</svg>`,
  bridge: `<svg viewBox="0 0 300 170" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
  <circle cx="150" cy="85" r="16"/>
  <circle cx="52" cy="38" r="7"/><line x1="150" y1="85" x2="52" y2="38"/>
  <circle cx="248" cy="38" r="7"/><line x1="150" y1="85" x2="248" y2="38"/>
  <circle cx="40" cy="128" r="7"/><line x1="150" y1="85" x2="40" y2="128"/>
  <circle cx="260" cy="128" r="7"/><line x1="150" y1="85" x2="260" y2="128"/>
  <circle cx="150" cy="22" r="6"/><line x1="150" y1="85" x2="150" y2="22"/>
  <g fill="currentColor" stroke="none"><circle cx="92" cy="62" r="2.5"/><circle cx="208" cy="62" r="2.5"/><circle cx="86" cy="110" r="2.5"/><circle cx="212" cy="110" r="2.5"/><circle cx="150" cy="54" r="2.5"/></g>
</svg>`,
  studio: `<svg viewBox="0 0 300 170" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
  <rect x="18" y="18" width="264" height="134" rx="8"/>
  <line x1="18" y1="38" x2="282" y2="38"/>
  <g stroke-width="1" fill="currentColor" stroke="none"><circle cx="32" cy="28" r="3.5"/><circle cx="44" cy="28" r="3.5"/><circle cx="56" cy="28" r="3.5"/></g>
  <rect x="32" y="52" width="148" height="30" rx="5"/>
  <path d="M40 60h80M40 72h58" stroke-width="1.2"/>
  <rect x="32" y="96" width="220" height="26" rx="5"/>
  <path d="M44 105h100M44 113h68" stroke-width="1.2"/>
  <path d="M246 104l18 9-18 9" stroke-width="1.8"/>
  <rect x="32" y="130" width="40" height="10" rx="3" fill="currentColor" stroke="none" opacity="0.4"/>
</svg>`,
};

const flagify = (t) => '--' + t.toLowerCase().replace(/\s+/g, '-');

const sites = SITES.filter((s) => s.name !== current).map((s) => ({
  ...s,
  art: MOTIFS[s.motif] || MOTIFS.graph,
  flags: s.tags.map(flagify).join(' '),
  url: s.href.replace(/^https?:\/\//, ''),
}));
const featuredIdx = Math.floor(Math.random() * sites.length);
---

<section class="same-garden" aria-labelledby="sg-h">
  <div class="sg-inner">
    <div class="sg-head">
      <span class="kicker sg-kicker">From the toolbox</span>
      <h2 class="sg-h2" id="sg-h">More tools. Same ethos.</h2>
      <p class="sg-sub">Local-first, no cloud dependency, no checkmark you can't re-run.</p>
    </div>
    <div class="sg-grid">
      {sites.map((s, i) => (
        <a class={`sg-card${i === featuredIdx ? ' sg-card--featured' : ''}`} href={s.href} aria-label={`Visit ${s.name}: ${s.tagline}`}>
          <div class="sg-bar">
            <span class="sg-dots" aria-hidden="true"><i></i><i></i><i></i></span>
            <span class="sg-url">
              <svg class="sg-lock" viewBox="0 0 24 24" width="9" height="9" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
              {s.url}
            </span>
          </div>
          <div class="sg-hero">
            <div class="sg-hero-art" set:html={s.art} />
            <span class="sg-scan" aria-hidden="true"></span>
            <div class="sg-hero-copy">
              <span class="sg-eyebrow">{s.name}</span>
              <h3 class="sg-headline">{s.tagline}</h3>
              <p class="sg-blurb">{s.blurb}</p>
            </div>
          </div>
          <div class="sg-status">
            <span class="sg-flags">{s.flags}</span>
            <span class="sg-visit">visit <span class="sg-arrow">↗</span></span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style is:global>
.same-garden{ border-top:1px solid var(--hairline); padding:clamp(48px,8vh,96px) 0; scroll-snap-align:start; min-height:100svh; display:flex; flex-direction:column; justify-content:center;
  --sg-accent: var(--accent); --sg-screen:#e7e0cb; --sg-ink:#1b2a34;
  --sg-nav: rgba(13,17,23,.92); } /* match the Topbar/Footer nav background */
[data-theme="light"] .same-garden{ --sg-accent: color-mix(in oklab, var(--accent) 80%, #fff); --sg-nav: rgba(24,47,60,.94); }
/* Phones: the 100svh + vertical-centering left a big dead band above the toolbox
   when the cards stack to one column — make the section content-height instead. */
@media(max-width:768px){ .same-garden{ min-height:auto; justify-content:flex-start; padding:clamp(40px,6vh,64px) 0; } }
.same-garden .sg-inner{ max-width:1240px; margin:0 auto; padding:0 28px; width:100%; }
.same-garden .sg-head{ text-align:center; margin-bottom:clamp(28px,4vh,44px); }
.same-garden .sg-kicker{ color:var(--accent); }
.same-garden .sg-kicker::before, .same-garden .sg-kicker::after{ content:''; display:inline-block; width:22px; height:1px; background:var(--accent); vertical-align:middle; margin-bottom:3px; }
.same-garden .sg-kicker::before{ margin-right:10px; } .same-garden .sg-kicker::after{ margin-left:10px; }
.same-garden .sg-h2{ font-family:var(--font-display); font-weight:900; font-stretch:125%; font-size:clamp(2rem,4vw,3rem); color:var(--ink); margin:12px 0 0; letter-spacing:-.02em; }
.same-garden .sg-sub{ font-family:var(--font-mono); font-size:.74rem; color:var(--muted); margin:14px auto 0; max-width:52ch; line-height:1.6; }
.same-garden .sg-grid{ display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:18px; }

.same-garden .sg-card--featured { grid-column: span 2; }
@media(max-width:768px){ .same-garden .sg-card--featured { grid-column: span 1; } }
.same-garden .sg-card--featured .sg-headline { font-size: 1.7rem; max-width: 18ch; }
.same-garden .sg-card--featured .sg-blurb { max-width: 44ch; }

/* ── mini-browser card ──────────────────────────────────────────────────── */
.same-garden .sg-card{ position:relative; display:flex; flex-direction:column; overflow:hidden; border:1px solid var(--hairline-strong); border-radius:12px; background:color-mix(in oklab, var(--surface) 82%, transparent); text-decoration:none; transition:border-color .28s var(--ease), transform .28s var(--ease), box-shadow .28s var(--ease); }
.same-garden .sg-card:hover{ border-color:color-mix(in oklab, var(--accent) 55%, var(--hairline-strong)); transform:translateY(-4px); box-shadow:0 28px 54px -28px rgba(0,0,0,.7); }

/* browser bar */
.same-garden .sg-bar{ display:flex; align-items:center; gap:12px; height:38px; padding:0 14px; border-bottom:1px solid var(--hairline); background:var(--sg-nav); }
.same-garden .sg-dots{ display:inline-flex; gap:6px; flex-shrink:0; }
.same-garden .sg-dots i{ width:9px; height:9px; border-radius:50%; background:var(--faint); transition:background .25s var(--ease); }
.same-garden .sg-card:hover .sg-dots i:nth-child(1){ background:var(--sg-accent); }
.same-garden .sg-url{ display:inline-flex; align-items:center; gap:6px; flex:1; min-width:0; height:22px; padding:0 10px; border-radius:999px; background:color-mix(in oklab, var(--canvas) 60%, transparent); border:1px solid var(--hairline); font-family:var(--font-mono); font-size:.68rem; color:var(--muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; transition:color .25s var(--ease), border-color .25s var(--ease); }
.same-garden .sg-lock{ flex-shrink:0; opacity:.7; }
.same-garden .sg-card:hover .sg-url{ color:var(--sg-accent); border-color:color-mix(in oklab, var(--accent) 40%, var(--hairline)); }

/* light hero viewport — the tool's motif as imagery + headline */
.same-garden .sg-hero{ position:relative; overflow:hidden; flex:1; min-height:158px; padding:22px 20px;
  /* echo of the site background glow, scaled into the "page": warm top-right + faint cool bottom-left */
  background:
    radial-gradient(ellipse 60% 80% at 96% -10%, rgba(255,218,25,.30), transparent 62%),
    radial-gradient(ellipse 55% 65% at -6% 110%, rgba(121,192,255,.16), transparent 60%),
    var(--sg-screen); }
.same-garden .sg-hero-art{ position:absolute; inset:0; color:var(--sg-ink); opacity:.11; }
.same-garden .sg-hero-art svg{ position:absolute; inset:0; width:100%; height:100%; }
.same-garden .sg-scan{ position:absolute; left:0; right:0; top:0; height:2px; background:var(--accent); box-shadow:0 0 10px var(--accent); opacity:0; }
.same-garden .sg-card:hover .sg-scan{ animation:sg-scan 1s var(--ease); }
@keyframes sg-scan{ 0%{ transform:translateY(0); opacity:0; } 12%{ opacity:.85; } 88%{ opacity:.85; } 100%{ transform:translateY(220px); opacity:0; } }
.same-garden .sg-hero-copy{ position:relative; }
.same-garden .sg-eyebrow{ font-family:var(--font-mono); font-size:.62rem; letter-spacing:.16em; text-transform:uppercase; color:color-mix(in oklab, var(--sg-ink) 60%, transparent); }
.same-garden .sg-headline{ font-family:var(--font-display); font-weight:900; font-stretch:115%; font-size:1.4rem; line-height:1.04; letter-spacing:-.01em; color:var(--sg-ink); margin:8px 0 0; max-width:14ch; }
.same-garden .sg-blurb{ font-size:.82rem; line-height:1.55; color:color-mix(in oklab, var(--sg-ink) 72%, transparent); margin:10px 0 0; max-width:34ch; }

/* browser status bar */
.same-garden .sg-status{ display:flex; align-items:center; justify-content:space-between; gap:12px; height:40px; padding:0 16px; border-top:1px solid var(--hairline); background:var(--sg-nav); }
.same-garden .sg-flags{ font-family:var(--font-mono); font-size:.62rem; letter-spacing:.02em; color:var(--muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.same-garden .sg-visit{ font-family:var(--font-mono); font-size:.66rem; letter-spacing:.08em; text-transform:uppercase; color:var(--faint); white-space:nowrap; flex-shrink:0; transition:color .22s var(--ease); }
.same-garden .sg-arrow{ display:inline-block; transition:transform .22s var(--ease); }
.same-garden .sg-card:hover .sg-visit{ color:var(--sg-accent); }
.same-garden .sg-card:hover .sg-arrow{ transform:translate(3px,-3px); }
.same-garden .sg-card:focus-visible{ outline:2px solid var(--accent); outline-offset:3px; }

@media (prefers-reduced-motion:reduce){
  .same-garden .sg-card:hover .sg-scan{ animation:none; }
  .same-garden .sg-card{ transition:border-color .2s, box-shadow .2s; }
  .same-garden .sg-card:hover{ transform:none; }
}
</style>
