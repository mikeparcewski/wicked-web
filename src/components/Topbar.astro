---
/**
 * Topbar.astro — fixed nav header. Canonical for the wicked-* family.
 * CSS is is:global so the class names survive and the dropdown / theme
 * scripts still match.
 *
 * Props (per-site):
 *   pkg  — secondary header shown as "<logo> / <pkg>" in jetbrains-mono
 *          (e.g. "wicked-garden"). Omit on the umbrella site.
 *   repo — GitHub URL the header's GitHub icon points at (this page's repo).
 */
const {
  pkg = '',
  repo = 'https://github.com/mikeparcewski',
} = Astro.props;
---

<!-- TOPBAR -->
<header class="topbar">
  <div class="topbar__inner">
    <a href="https://wickedagile.com" class="wordmark" aria-label="wickedagile">
      <span class="wordmark-mark" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d1117" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5l3.5 14L12 8l5.5 11L21 5"/></svg>
      </span>
      <span><span class="wk">wicked</span><span class="ag">agile</span></span>
    </a>
    {pkg && (
      <span class="topbar-pkg">
        <span class="topbar-pkg-sep" aria-hidden="true">/</span>{pkg}
      </span>
    )}
    <nav class="nav">
      <div class="dropdown-wrap nav-inline" data-tip="ecosystem">
        <button class="icon-btn" id="projectsBtn" aria-label="Browse projects" aria-expanded="false" aria-haspopup="true">
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><rect x=".5" y=".5" width="5" height="5" rx="1.2" fill="currentColor"/><rect x="8.5" y=".5" width="5" height="5" rx="1.2" fill="currentColor"/><rect x=".5" y="8.5" width="5" height="5" rx="1.2" fill="currentColor"/><rect x="8.5" y="8.5" width="5" height="5" rx="1.2" fill="currentColor"/></svg>
        </button>
        <div class="dropdown-menu" id="projectsMenu" hidden>
          <span class="dropdown-kicker">wicked-* ecosystem</span>
          <a href="https://wg.wickedagile.com" class="dropdown-item">wicked-garden <span class="dropdown-tag">site ↗</span></a>
          <a href="https://wi.wickedagile.com" class="dropdown-item">wicked-interactive <span class="dropdown-tag">site ↗</span></a>
          <a href="https://ws.wickedagile.com" class="dropdown-item">wicked-studio <span class="dropdown-tag">site ↗</span></a>
          <a href="https://wt.wickedagile.com" class="dropdown-item">wicked-testing <span class="dropdown-tag">site ↗</span></a>
          <a href="https://wsig.wickedagile.com" class="dropdown-item">wicked-signals <span class="dropdown-tag">site ↗</span></a>
          <a href="https://we.wickedagile.com" class="dropdown-item">wicked-estate <span class="dropdown-tag">site ↗</span></a>
          <div class="dropdown-divider"></div>
          <a href="https://github.com/mikeparcewski/wicked-brain" target="_blank" rel="noopener" class="dropdown-item">wicked-brain</a>
          <a href="https://github.com/mikeparcewski/wicked-bus" target="_blank" rel="noopener" class="dropdown-item">wicked-bus</a>
        </div>
      </div>
      <a href="https://medium.com/@mike.parcewski" class="icon-btn nav-inline" target="_blank" rel="noopener" aria-label="Medium" data-tip="writing">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M19.938 5.686L18.651 6.92a.376.376 0 0 0-.143.362v9.067a.376.376 0 0 0 .143.361l1.257 1.234v.271h-6.322v-.27l1.302-1.265c.128-.128.128-.165.128-.36V8.99l-3.62 9.195h-.49L6.69 8.99v6.163a.85.85 0 0 0 .233.707l1.694 2.054v.271H3.815v-.27L5.51 15.86a.82.82 0 0 0 .218-.707V8.027a.624.624 0 0 0-.203-.527L4.019 5.686v-.27h4.674l3.613 7.923 3.176-7.924h4.456v.271z"/></svg>
      </a>
      <a class="icon-btn nav-inline" href={repo} target="_blank" rel="noopener" aria-label="GitHub" data-tip="github">
        <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.02-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
      <button class="icon-btn" id="themeBtn" aria-label="Toggle theme" data-tip="toggle theme">
        <svg id="themeIcon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></svg>
      </button>
      <button class="icon-btn menu-btn" id="menuBtn" aria-label="Menu" aria-expanded="false" aria-controls="mobileMenu">
        <svg class="menu-ic menu-ic--bars" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg class="menu-ic menu-ic--x" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="5" y1="5" x2="19" y2="19"/><line x1="19" y1="5" x2="5" y2="19"/></svg>
      </button>
    </nav>
  </div>

  <!-- MOBILE MENU — the expand version of the nav, phones only -->
  <nav class="mobile-menu" id="mobileMenu" aria-label="wicked-* ecosystem" hidden>
    <span class="dropdown-kicker">wicked-* ecosystem</span>
    <a href="https://wg.wickedagile.com" class="mm-item">wicked-garden <span class="dropdown-tag">site ↗</span></a>
    <a href="https://wi.wickedagile.com" class="mm-item">wicked-interactive <span class="dropdown-tag">site ↗</span></a>
    <a href="https://ws.wickedagile.com" class="mm-item">wicked-studio <span class="dropdown-tag">site ↗</span></a>
    <a href="https://wt.wickedagile.com" class="mm-item">wicked-testing <span class="dropdown-tag">site ↗</span></a>
    <a href="https://wsig.wickedagile.com" class="mm-item">wicked-signals <span class="dropdown-tag">site ↗</span></a>
    <a href="https://we.wickedagile.com" class="mm-item">wicked-estate <span class="dropdown-tag">site ↗</span></a>
    <div class="dropdown-divider"></div>
    <a href="https://github.com/mikeparcewski/wicked-brain" target="_blank" rel="noopener" class="mm-item">wicked-brain <span class="dropdown-tag">repo ↗</span></a>
    <a href="https://github.com/mikeparcewski/wicked-bus" target="_blank" rel="noopener" class="mm-item">wicked-bus <span class="dropdown-tag">repo ↗</span></a>
    <div class="dropdown-divider"></div>
    <a href="https://medium.com/@mike.parcewski" target="_blank" rel="noopener" class="mm-item">Medium <span class="dropdown-tag">writing ↗</span></a>
    <a href={repo} target="_blank" rel="noopener" class="mm-item">GitHub <span class="dropdown-tag">this repo ↗</span></a>
  </nav>
</header>

<style is:global>
/* TOPBAR */
.topbar{position:fixed;top:0;left:0;right:0;z-index:200;height:var(--topbar-h);background:rgba(13,17,23,.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid var(--hairline-strong)}
[data-theme="light"] .topbar{background:rgba(24,47,60,.94)}
.topbar__inner{display:flex;align-items:center;justify-content:space-between;height:100%;padding:0 28px;max-width:1240px;margin:0 auto}
.wordmark{display:inline-flex;align-items:center;gap:10px;font-family:var(--font-display);font-weight:900;font-stretch:125%;font-size:1.22rem;letter-spacing:-.01em;color:var(--ink);text-decoration:none}
.wordmark-mark{width:28px;height:28px;border-radius:9px;background:var(--accent);display:grid;place-items:center;flex-shrink:0}
.wordmark .wk{color:var(--ink)}
.wordmark .ag{color:var(--accent)}
/* secondary header: "<logo> / <package>" in jetbrains-mono. margin-right:auto
   keeps logo+pkg grouped on the left and pushes the nav to the right. */
.topbar-pkg{display:inline-flex;align-items:center;gap:8px;margin-left:7px;margin-right:auto;font-family:var(--font-mono);font-weight:500;font-size:.92rem;letter-spacing:.01em;color:var(--muted)}
.topbar-pkg-sep{color:var(--faint);font-weight:400}
@media(max-width:560px){.topbar-pkg{display:none}}
.nav{display:flex;align-items:center;gap:12px}
[data-tip]{position:relative}
[data-tip]::after{content:attr(data-tip);position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);background:rgba(0,0,0,.92);color:#e6edf3;font-family:var(--font-mono);font-size:.6rem;white-space:nowrap;padding:4px 9px;border-radius:5px;border:1px solid var(--hairline-strong);pointer-events:none;opacity:0;transition:opacity .18s;z-index:300}
[data-tip]:hover::after{opacity:1}
.icon-btn{display:inline-grid;place-items:center;width:36px;height:36px;border-radius:999px;border:1px solid var(--hairline-strong);color:var(--ink);background:transparent;cursor:pointer;text-decoration:none;transition:border-color .25s var(--ease),color .25s var(--ease),background .25s var(--ease);padding:0;font-size:inherit;text-transform:none;flex-shrink:0}
.icon-btn:hover{border-color:var(--accent);background:var(--accent);color:var(--accent-ink)}
.icon-btn svg{display:block}
.dropdown-wrap{position:relative}
.dropdown-menu{position:absolute;top:calc(100% + 8px);right:0;z-index:200;min-width:228px;background:var(--surface);border:1px solid var(--hairline-strong);border-radius:12px;padding:6px;box-shadow:0 18px 48px -14px rgba(0,0,0,.7)}
.dropdown-kicker{display:block;font-family:var(--font-mono);font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);padding:7px 10px 5px}
.dropdown-item{display:flex;justify-content:space-between;align-items:center;padding:8px 10px;border-radius:6px;color:var(--ink);font-size:.82rem;text-decoration:none;transition:background .15s,color .15s}
.dropdown-item:hover{background:rgba(255,218,25,.14);color:var(--ink)}
.dropdown-tag{font-family:var(--font-mono);font-size:.6rem;color:var(--faint);letter-spacing:.1em}
.dropdown-divider{height:1px;background:var(--hairline);margin:4px 0}

/* ── MOBILE EXPAND NAV (hamburger) ─────────────────────────────────────────
   Desktop: inline icon cluster (.nav-inline) shows, hamburger + panel hidden.
   Phones ≤640px: collapse ecosystem/Medium/GitHub behind a hamburger; the
   theme toggle stays inline. Prevents the right-edge clip on small screens. */
.menu-btn{display:none}
.menu-btn .menu-ic--x{display:none}
.menu-btn[aria-expanded="true"] .menu-ic--bars{display:none}
.menu-btn[aria-expanded="true"] .menu-ic--x{display:block}
.mobile-menu{display:none}
.mobile-menu .dropdown-kicker{padding:11px 12px 6px}
.mobile-menu .dropdown-divider{margin:6px 10px}
.mm-item{display:flex;justify-content:space-between;align-items:center;gap:12px;min-height:46px;padding:11px 12px;border-radius:8px;color:var(--ink);font-family:var(--font-display);font-weight:600;font-size:1.02rem;letter-spacing:-.01em;text-decoration:none;transition:background .15s}
.mm-item:hover,.mm-item:active{background:rgba(255,218,25,.14)}
.mm-item .dropdown-tag{font-family:var(--font-mono);font-weight:400;font-size:.62rem;color:var(--faint);letter-spacing:.1em;text-transform:uppercase;flex-shrink:0}
@keyframes mm-in{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:640px){
  .nav{gap:8px}
  .nav-inline{display:none}
  .menu-btn{display:inline-grid}
  .mobile-menu:not([hidden]){display:block;position:fixed;top:var(--topbar-h);left:0;right:0;z-index:199;background:var(--surface);border-bottom:1px solid var(--hairline-strong);box-shadow:0 18px 48px -14px rgba(0,0,0,.7);padding:8px 14px calc(14px + env(safe-area-inset-bottom));max-height:calc(100svh - var(--topbar-h));overflow-y:auto;animation:mm-in .2s var(--ease)}
}
@media(prefers-reduced-motion:reduce){.mobile-menu:not([hidden]){animation:none}}
</style>

<script is:inline>
(function () {
  'use strict';

  /* THEME */
  var SUN = '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
  var MOON = '<path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/>';
  function setTheme(t){document.documentElement.setAttribute('data-theme',t);localStorage.setItem('wa-theme',t);var ic=document.getElementById('themeIcon');if(ic)ic.innerHTML=t==='light'?MOON:SUN}
  /* respect the no-flash init already on <html>, falling back to stored/default */
  setTheme(document.documentElement.getAttribute('data-theme')||localStorage.getItem('wa-theme')||'light');
  var themeBtn=document.getElementById('themeBtn');
  if(themeBtn)themeBtn.addEventListener('click',function(){setTheme(document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark')});

  /* DROPDOWN */
  (function(){
    var btn=document.getElementById('projectsBtn'),menu=document.getElementById('projectsMenu');
    if(!btn||!menu)return;
    btn.addEventListener('click',function(e){e.stopPropagation();var o=!menu.hidden;menu.hidden=o;btn.setAttribute('aria-expanded',!o)});
    document.addEventListener('click',function(){menu.hidden=true;btn.setAttribute('aria-expanded','false')});
    document.addEventListener('keydown',function(e){if(e.key==='Escape'){menu.hidden=true;btn.setAttribute('aria-expanded','false')}});
  })();

  /* MOBILE MENU (hamburger expand nav) */
  (function(){
    var mb=document.getElementById('menuBtn'),mm=document.getElementById('mobileMenu');
    if(!mb||!mm)return;
    function closeMenu(){mm.hidden=true;mb.setAttribute('aria-expanded','false')}
    mb.addEventListener('click',function(e){e.stopPropagation();if(mm.hidden){mm.hidden=false;mb.setAttribute('aria-expanded','true')}else{closeMenu()}});
    mm.addEventListener('click',function(e){e.stopPropagation()});
    document.addEventListener('click',closeMenu);
    document.addEventListener('keydown',function(e){if(e.key==='Escape')closeMenu()});
    window.addEventListener('resize',function(){if(window.innerWidth>640)closeMenu()});
  })();
})();
</script>
